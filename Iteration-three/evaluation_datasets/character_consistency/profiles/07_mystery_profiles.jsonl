{"sample_id": "char_mystery_001", "genre": "mystery", "character_profile": {"name": "老李", "age": 52, "identity": "刑侦队长", "personality": "经验丰富，观察入微，外表粗犷内心细腻", "background": "干刑侦二十八年，破获大案要案无数。没什么文化但直觉极准。妻子早逝，独自把女儿养大。", "speaking_style": "说话接地气，爱用俗语俚语，审讯时语言犀利，平时温和", "core_traits": ["观察力强", "经验丰富", "接地气", "执着", "有同情心"], "relationships": {"小王（徒弟）": "嘴上嫌弃实则精心培养", "女儿": "亏欠但深爱"}}, "utterances": [{"utterance_id": "char_mystery_001_u01", "context": "勘察案发现场", "text": "别动！那个杯子上的指纹可能还有用。先拍照再取证。", "is_consistent": true, "rationale": "经验丰富的现场指挥"}, {"utterance_id": "char_mystery_001_u02", "context": "小王发现一个线索", "text": "不错啊小子，眼睛挺尖。这回没白带你。", "is_consistent": true, "rationale": "嘴上肯定徒弟"}, {"utterance_id": "char_mystery_001_u03", "context": "审讯嫌疑人", "text": "你星期二晚上八点在哪？别想编，我们查过监控了。", "is_consistent": true, "rationale": "审讯时犀利直接"}, {"utterance_id": "char_mystery_001_u04", "context": "在办公室和同事聊天", "text": "哎呀我跟你们说，我昨晚看了个韩剧，男主角太帅了！你们看了吗？", "is_consistent": false, "rationale": "和五十多岁老刑警的形象完全不搭", "error_type": "speech_style_break"}, {"utterance_id": "char_mystery_001_u05", "context": "受害者家属哭泣", "text": "你放心，这个案子我管定了。一定给你一个交代。", "is_consistent": true, "rationale": "给受害者家属承诺"}, {"utterance_id": "char_mystery_001_u06", "context": "案子陷入僵局", "text": "小王，把案卷从头再梳理一遍。肯定有我们漏掉的东西。", "is_consistent": true, "rationale": "不放弃，执着"}, {"utterance_id": "char_mystery_001_u07", "context": "女儿打电话来", "text": "爸今晚又加班，你自己吃饭。冰箱里有菜，热一下就行。", "is_consistent": true, "rationale": "工作家庭难两全"}, {"utterance_id": "char_mystery_001_u08", "context": "分析作案动机", "text": "盗窃杀人？不对。贵重物品没丢。这大概率是仇杀或者情杀。", "is_consistent": true, "rationale": "推理合理"}, {"utterance_id": "char_mystery_001_u09", "context": "新人问他为什么当警察", "text": "说出来你别笑。我小时候邻居家被偷了，警察三天破了案，我觉得特神。", "is_consistent": true, "rationale": "朴实的理由"}, {"utterance_id": "char_mystery_001_u10", "context": "结案后", "text": "收工。今晚我请客，吃火锅去。", "is_consistent": true, "rationale": "案子破了后的轻松"}], "evaluation_summary": {"character_fidelity": 0.9, "world_consistency": 0.85, "hallucination": 0.08,